// EXPECT: fail
// DIAGNOSTICS:
// - E0241
// NOTE:
//   Forces assignment RHS evaluation to fail inside the evaluator by using a
//   bool literal condition in a comptime if-expression.

comptime fn bad_assignment_rhs() -> u32 {
    var value: u32 = 0;
    value = if (false) 1 else 2;
    return value;
}

reg const folded: u32 = bad_assignment_rhs();
