// EXPECT: pass
// STAGE: bound
// CONTAINS:
// - folded: u32
// - Literal<u32> 2
// ! Call<u32> bad_assignment_rhs
// NOTE:
//   Bool literal conditions in comptime if-expressions should fold cleanly.

comptime fn bad_assignment_rhs() -> u32 {
    var value: u32 = 0;
    value = if (false) 1 else 2;
    return value;
}

reg const folded: u32 = bad_assignment_rhs();
