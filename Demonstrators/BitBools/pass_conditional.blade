// EXPECT: pass
// STAGE: final-asm
// CONTAINS:
// - CMP
// - IF_NZ
// NOT_CONTAINS:
// - WRZ
// - TJZ
// NOTE:
//   Verifies that a comparison used only as a branch condition emits
//   CMP + predicated JMP without materializing to a register.

reg var a: u32 = 0;
reg var b: u32 = 0;

if(a == b) {
    asm volatile { 
        COGATN #1 
    };
}
else {
    asm volatile { 
        COGATN #2
    };
}
