// EXPECT: fail
// ARGS:
// - --module=extmod=../Modules/extmod.blade
// DIAGNOSTICS:
// - L36, E0243
// - L37, E0243
// - L38, E0242
// - L45, E0243
// - L46, E0243
// - L47, E0243
// - L48, E0242
// - L49, E0242
// - L50, E0242
// - L52, E0243
// - L51, E0242
// - L55, E0242
// - L56, E0242
// - L57, E0242
// NOTE:
//   Forces comptime-required contexts through binder-side folding, validation, and failure reporting.

import extmod as ext;

type Pair = struct {
    value: u32,
};

reg var seed: u32 = 1;
reg var values: [1]u32 = [1];
reg var ptr: *reg u32 = undefined;
reg var pair: Pair = .{ .value = 1 };

fn runtime_u32() -> u32 { return 1; }
fn runtime_bool() -> bool { return true; }

comptime fn read_global() -> u32 { return seed; }
comptime fn write_global() -> u32 { seed = 2; return 0; }
comptime fn use_intrinsic() -> u32 { return @encod(1); }

reg const bad_direct_call: u32 = runtime_u32();
reg const bad_read_global: u32 = read_global();
reg const bad_write_global: u32 = write_global();
reg const bad_intrinsic_call: u32 = use_intrinsic();

extern reg var check_unary: u32 @(-seed);
extern reg var check_binary: u32 @(seed + 1);
extern reg var check_if: u32 @(if (true) seed else 1);
extern reg var check_member: u32 @(pair.value);
extern reg var check_index: u32 @(values[0]);
extern reg var check_deref: u32 @(*ptr);
extern reg var check_module: u32 @(ext());
extern reg var check_symbol: u32 @(seed);

reg const check_array_call: [1]u32 = [runtime_u32()];
reg const check_array_conversion: [1]u8 = [@encod(1)];
reg const check_array_cast: [1]u8 = [@encod(1) as u8];
reg const check_array_bitcast: [1]u32 = [bitcast(u32, @encod(1))];
