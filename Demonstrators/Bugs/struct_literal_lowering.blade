// EXPECT: pass
// STAGE: final-asm
// CONTAINS:
// - RDLONG
// - WRLONG
// - ADD
// NOT_CONTAINS:
// - unhandled: structlit
// - unhandled: load.member
// - unhandled: insert.member
// NOTE:
//   Single-word struct literals and member updates lower end-to-end.
//   The hub-backed struct update should emit a read-modify-write sequence.

type Pair = struct {
    value: u32,
};

hub var pair: Pair = Pair {
    .value = 1,
};

reg var sink: u32 = 0;

sink = pair.value;
pair.value = sink + 1;
