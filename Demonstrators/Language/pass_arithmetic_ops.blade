// EXPECT: pass
// STAGE: final-asm
// CONTAINS:
// - ADD
// - QMUL
// - QDIV
// - GETQX
// - GETQY
// NOTE:
//   Exercises multiply, divide, modulo through full codegen pipeline.

extern reg var OUTA: u32 @(0x1FC);

noinline fn math(a: u32, b: u32) -> u32 {
    var product: u32 = a * b;
    var quotient: u32 = product / a;
    var remainder: u32 = product % b;
    return product + quotient + remainder;
}

reg var a: u32 = 10;
reg var b: u32 = 20;
OUTA = math(a, b);
