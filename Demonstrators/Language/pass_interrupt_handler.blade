// EXPECT: xfail
// NOTE:
//   Exercises interrupt handler (int1 fn) with yield and return.
//   Currently xfail because yield codegen is not fully implemented.

extern reg var OUTA: u32 @(0x1FC);

reg var counter: u32 = 0;

int1 fn on_interrupt() {
    counter = counter + 1;
    yield;
    counter = counter + 1;
    return;
}

OUTA = counter;
