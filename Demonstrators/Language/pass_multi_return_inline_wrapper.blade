// EXPECT: pass
// NOTE:
//   Tests that a multi-return noinline call inside an inlined function
//   is correctly cloned during inlining.

noinline fn get_pair(a: u32) -> u32, bool {
    if (a > 10) {
        return a, true;
    }
    else {
        return 0, false;
    }
}

reg var val: u32 = 0;
reg var flag: bool = false;

fn wrapper(x: u32) {
    val, flag = get_pair(x);
}

reg const input: u32 = 42;

wrapper(input);
