// EXPECT: pass
// NOTE:
//   Exercises for-loop array iteration forms over reg-backed arrays so the
//   backend uses the supported indexed load/store lowering paths.

reg var arr: [4]u32 = [1,2,3,4];
reg var sink: u32 = 0;

for (arr) -> x { sink = sink + x; }
for (arr) -> &x { x = 10; }
for (arr) -> &x, i { x = i; }
