// EXPECT: pass
// NOTE:
//   Exercises rep-for setup/iter rewrite paths via a single-callsite inlineable helper.

cog var count: u32 = 4;
cog var sink: u32 = 0;

fn inline_rep_for(n: u32) -> u32 {
    var sum: u32 = 0;
    rep for(n) -> i {
        sum = sum + i;
    }
    return sum;
}

sink = inline_rep_for(count);
