// - Literal<MemorySpace> 1
// - Literal<MemorySpace> 2
// NOTE:
//   Tests memoryof operator returning MemorySpace enum values
//   for reg, lut, and hub variables.

import builtin;

extern reg var rv: u32;
extern lut var lv: u32;
extern hub var hv: u32;

reg var cls: builtin.MemorySpace = memoryof(rv);
reg var cls2: builtin.MemorySpace = memoryof(lv);
reg var cls3: builtin.MemorySpace = memoryof(hv);
