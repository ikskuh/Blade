// EXPECT: pass
// STAGE: mir
// ARGS:
// - -fno-mir-opt=*
// CONTAINS:
// - %v1:u32 = copy %v0
// - %v4:u32 = binary.Add %v1, %v3
// NOTE:
//   Unary plus materializes a MIR copy. With copy-prop disabled, later uses still
//   read through the copied value.

reg var sink: u32 = 0;

noinline fn demo(x: u32) -> u32 {
    var y: u32 = +x;
    return y + 1;
}

sink = demo(2);
