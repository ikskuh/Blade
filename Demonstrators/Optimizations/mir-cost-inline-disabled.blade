// EXPECT: pass
// STAGE: mir
// ARGS:
// - -fno-mir-opt=*
// CONTAINS:
// - call add1(
// - call demo(
// NOTE:
//   Negative case for MIR cost-inline: with MIR optimizations disabled, both calls remain.

reg var sink: u32 = 0;

noinline fn add1(x: u32) -> u32 {
    return x + 1;
}

noinline fn demo(x: u32) -> u32 {
    return add1(x);
}

sink = demo(7);
