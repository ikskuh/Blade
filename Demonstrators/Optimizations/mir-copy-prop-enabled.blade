// EXPECT: pass
// STAGE: mir
// ARGS:
// - -fno-mir-opt=*
// - -fmir-opt=copy-prop
// CONTAINS:
// - %v1:u32 = copy %v0
// - %v4:u32 = binary.Add %v0, %v3
// NOTE:
//   Unary plus materializes a MIR copy. Copy-prop rewrites the later add to use
//   the original value directly, but does not itself remove the now-dead copy.

reg var sink: u32 = 0;

noinline fn demo(x: u32) -> u32 {
    var y: u32 = +x;
    return y + 1;
}

sink = demo(2);
