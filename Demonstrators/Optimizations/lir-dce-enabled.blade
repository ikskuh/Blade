// EXPECT: pass
// STAGE: lir
// ARGS:
// - -fno-mir-opt=*
// - -fno-lir-opt=*
// - -flir-opt=dce
// CONTAINS:
// ! binary.Add
// NOTE:
//   Positive case for LIR dce: the dead addition should be removed.

reg var sink: u32 = 0;
reg var input: u32 = 5;

noinline fn demo(x: u32) -> u32 {
    var y: u32 = x + 1;
    return x;
}

sink = demo(input);
