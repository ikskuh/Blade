// EXPECT: pass
// STAGE: asmir
// ARGS:
// - -fno-asmir-opt=*
// CONTAINS:
// - MOV _r1, _r1
// - OR _r1, #0
// - ADD _r1, #0
// SEQUENCE:
// - JMP #blade_halt
// NOTE:
//   Negative case for elide-nops: with optimization disabled, the inline no-ops remain
//   and the entry-point exit still targets the runtime halt hook.

cog var sink: u32 = 0;
var x: u32 = 1;
asm {
  MOV {x}, {x}
  OR {x}, #0
  ADD {x}, #0
};
sink = x;
