// EXPECT: pass
// STAGE: mir
// ARGS:
// - --no-single-callsite-inline
// - -fno-mir-opt=*
// CONTAINS:
// - branch %v1 ? bb2() : bb3()
// NOTE:
//   Negative case for MIR cfg-simplify: the original branch fanout remains.

reg var sink: u32 = 0;
reg var input: bool = false;

fn demo(x: bool) -> u32 {
    var y: u32 = 1;
    if (x) {
        y = y + 1;
    }

    return y;
}

sink = demo(input);
