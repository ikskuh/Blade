// EXPECT: pass
// STAGE: asmir
// ARGS:
// - --no-single-callsite-inline
// - -fno-mir-opt=*
// - -fno-lir-opt=*
// - -fno-asmir-opt=*
// CONTAINS:
// - RET
// NOT_CONTAINS:
// - _RET_ MOV #PA, #_r1
// NOTE:
//   Negative case for ASMIR ret-fusion: the leaf return stays as a standalone RET.

reg var sink: u32 = 0;

fn add1(x: u32) -> u32 {
    return x + 1;
}

sink = add1(1);
