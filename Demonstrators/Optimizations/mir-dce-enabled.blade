// STAGE: mir
// ARGS:
// - -fno-mir-opt=*
// - -fmir-opt=dce
// CONTAINS:
// ! binary.Add
// NOTE:
//   Positive case for MIR dce: the dead addition should be removed.

cog var sink: u32 = 0;
cog var input: u32 = 5;

noinline fn demo(x: u32) -> u32 {
    var y: u32 = x + 1;
    return x;
}

sink = demo(input);
