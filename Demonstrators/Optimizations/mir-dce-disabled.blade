// EXPECT: pass
// STAGE: mir
// ARGS:
// - -fno-mir-opt=*
// CONTAINS:
// - binary.Add
// NOTE:
//   Negative case for MIR dce: the dead addition is still present.

reg var sink: u32 = 0;
reg var input: u32 = 5;

noinline fn demo(x: u32) -> u32 {
    var y: u32 = x + 1;
    return x;
}

sink = demo(input);
