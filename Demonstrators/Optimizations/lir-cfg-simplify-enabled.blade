// EXPECT: pass
// STAGE: lir
// ARGS:
// - -fno-mir-opt=*
// - -fno-lir-opt=*
// - -flir-opt=cfg-simplify
// CONTAINS:
// - branch %r0 ? bb2() : bb1(
// NOT_CONTAINS:
// - branch %r0 ? bb2() : bb3()
// NOTE:
//   Positive case for LIR cfg-simplify: the trivial false-edge block should be threaded away.

reg var sink: u32 = 0;
reg var input: bool = false;

noinline fn demo(x: bool) -> u32 {
    var y: u32 = 1;
    if (x) {
        y = y + 1;
    }

    return y;
}

sink = demo(input);
