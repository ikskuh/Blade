// EXPECT: pass
// STAGE: lir
// ARGS:
// - --no-single-callsite-inline
// - -fno-mir-opt=*
// - -fno-lir-opt=*
// CONTAINS:
// - branch %r0 ? bb2() : bb3()
// NOTE:
//   Negative case for LIR cfg-simplify: the original branch fanout remains.

reg var sink: u32 = 0;
reg var input: bool = false;

fn demo(x: bool) -> u32 {
    var y: u32 = 1;
    if (x) {
        y = y + 1;
    }

    return y;
}

sink = demo(input);
