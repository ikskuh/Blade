reg var sink: u32 = 0;

fn src(x: u32) -> u32 {
    var y: u32 = x;
    var z: u32 = y + 1;
    return z;
}

fn top(v: u32) -> u32 {
    var t: u32 = src(v);
    return t;
}

sink = top(7);
