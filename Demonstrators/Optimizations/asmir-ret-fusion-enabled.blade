// EXPECT: pass
// STAGE: asmir
// ARGS:
// - -fno-mir-opt=*
// - -fno-lir-opt=*
// - -fno-asmir-opt=*
// - -fasmir-opt=ret-fusion
// CONTAINS:
// - _RET_ MOV #PA, #_r1
// NOTE:
//   Positive case for ASMIR ret-fusion: the RET should fuse into the preceding instruction.

reg var sink: u32 = 0;

noinline fn add1(x: u32) -> u32 {
    return x + 1;
}

sink = add1(1);
