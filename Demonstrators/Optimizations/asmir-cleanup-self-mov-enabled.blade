// EXPECT: pass
// STAGE: asmir
// ARGS:
// - -fno-asmir-opt=*
// - -fasmir-opt=cleanup-self-mov
// CONTAINS:
// ! MOV #_r1, #_r1
// NOTE:
//   Positive case for ASMIR cleanup-self-mov: the redundant self-move should be removed.

reg var sink: u32 = 0;
var x: u32 = 1;

asm {
  MOV {x}, {x}
};

sink = x;
