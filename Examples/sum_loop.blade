// Starter example: top-level automatic values plus a simple while loop.

fn sum_to(limit: u32) -> u32 {
    var total: u32 = 0;
    var i: u32 = 0;

    while (i < limit) {
        total += i;
        i += 1;
    }

    return total;
}

cog task main
{
    var requested_limit: u32 = 8;
    cog var total_sum: u32 = 0;

    total_sum = sum_to(requested_limit);
}
