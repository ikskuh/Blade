{
  "mcpServers": {
    "blade_compiler_service": {
      "type": "stdio",
      "command": ".venv/bin/python",
      "args": [
        "Scripts/mcp_server.py"
      ],
      "env": {}
    },
    "serena": {
      "type": "stdio",
      "command": ".venv/bin/serena",
      "args": [
        "start-mcp-server",
        "--context=codex",
        "--mode",
        "planning",
        "--mode",
        "editing",
        "--mode",
        "interactive",
        "--open-web-dashboard",
        "false"
      ],
      "env": {
        "PATH": "/home/felix/.dotnet/tools:/usr/local/sbin:/usr/local/bin:/usr/bin",
        "MCP_DEBUG": "1"
      }
    }
  }
}