// Basic inline assembly with common P2 instructions
reg var x: u32 = 0;
reg var y: u32 = 42;

fn add_values(a: u32, b: u32) -> u32 {
    reg var result: u32 = 0;
    asm {
        MOV {result}, {a}
        ADD {result}, {b}
    };
    return result;
}

fn bitwise_ops(val: u32, mask: u32) -> u32 {
    reg var out: u32 = 0;
    asm {
        MOV {out}, {val}
        AND {out}, {mask}
    };
    return out;
}

x = add_values(10, 32);
y = bitwise_ops(x, 0xFF);
