
[*.cs]

# This file is the local source of truth for Blade's analyzer policy.
# Keep the enabled/disabled set documented here so contributors can see both
# the rule choice and the reason behind it without having to inspect CI output.
#
# If a single occurrence genuinely needs to violate a rule, prefer a very
# narrow in-source suppression with a strong explanation of why the code is
# safe as written. That decision must be visible to and understood by the
# programmer reviewing or maintaining the code later.

# Performance tuning is staged separately from correctness and API cleanup.
dotnet_diagnostic.CA1859.severity = none

# Nested helper types are fine in this compiler code base.
dotnet_diagnostic.CA1034.severity = none

# Implicit dependency on the current user's locale is not acceptable in a compiler.
dotnet_diagnostic.CA1305.severity = error

# String comparison intent must stay explicit.
dotnet_diagnostic.CA1307.severity = error

# Public and externally visible APIs must validate their inputs.
# Use Blade/Requires.cs helpers such as:
#   Requires.NotNull(parameter);
#   Requires.NonNegative(value);
#   Requires.InRange(value, min, max);
dotnet_diagnostic.CA1062.severity = error

# Small hot-path text emission cleanups are worthwhile in the compiler writers.
dotnet_diagnostic.CA1865.severity = error
dotnet_diagnostic.CA1834.severity = error

# Externally visible array properties are harder to reason about than immutable list shapes.
dotnet_diagnostic.CA1819.severity = error

# Blade is built as an executable, but its public surface is intentionally reused
# by tests and helper runners.
dotnet_diagnostic.CA1515.severity = none


[Diagnostics/DiagnosticCode.cs]

# Keep the diagnostic code in the identifier so developers can grep by E/W code quickly.
dotnet_diagnostic.CA1707.severity = none

# Blade intentionally does not define a synthetic zero-value "None" diagnostic code.
dotnet_diagnostic.CA1008.severity = none
