// EXPECT: pass
// STAGE: final-asm
// SEQUENCE:
// - MOV
// - ADD
// - MOV
// NOTE:
//   `asm fn` bodies can use `%N` scratch registers without declaring locals.

cog task main {
    cog var result: u32 = 0;

    asm fn add_vals() -> u32 {
        MOV %0, #10
        ADD %0, #20
        MOV {return}, %0
    }

    result = add_vals();
}
