// EXPECT: pass
// NOTE:
//   Exercises rep loop (infinite) lowering to REP with @label body-length calculation.
cog task main {
    
    extern cog var OUTA: u32 @(0x1FC);
    
    noinline fn spin_forever(value: u32) -> u32 {
        rep loop {
            OUTA = value;
        }
        return 0;
    }
    
    cog var v: u32 = 42;
    OUTA = spin_forever(v);
}