// EXPECT: pass
// STAGE: final-asm
// SEQUENCE:
// - GETNIB g_nibble, ?1, #3
// CONTAINS:
// ! AUGD
// ! AUGS
// - ?1 LONG $00000456
// NOTE:
//   GETNIB may AUG-extend the S operand, but the #N operand is immediate-only and must not trigger AUGD/AUGS.
cog task main {
    
    cog var nibble: u32 = 0;
    
    asm {
        GETNIB {nibble}, #1110, #3
    };
}
