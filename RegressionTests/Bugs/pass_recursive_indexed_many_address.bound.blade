// EXPECT: pass
// STAGE: bound
// CONTAINS:
// - Unary<*cog u32> AddressOf
// - Index<u32>
// NOTE:
//   Recursive indexed address-of only rejects local/parameter arrays. A [*]
//   pointer base is still allowed because the address comes from the pointer
//   value, not the recursive frame.
cog task main {
    
    rec fn demo(many: [*]cog u32) void {
        var ptr: *cog u32 = &many[1];
    }
}