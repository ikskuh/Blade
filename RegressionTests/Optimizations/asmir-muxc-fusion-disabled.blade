// EXPECT: pass
// STAGE: asmir
// ARGS:
// - -fno-asmir-opt=*
// CONTAINS:
// - IF_C OR ?1, ?2
// - IF_NC ANDN ?1, ?2
// ! MUXC ?1, ?2
// NOTE:
//   Negative case for muxc-fusion: with optimization disabled, the pair remains unfused.
cog task main {
    
    cog var sink: u32 = 0;
    var x: u32 = 1;
    var m: u32 = 2;
    asm {
      IF_C OR {x}, {m}
      IF_NC ANDN {x}, {m}
    };
    sink = x;
}