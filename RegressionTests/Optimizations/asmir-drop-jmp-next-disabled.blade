// EXPECT: pass
// STAGE: asmir
// ARGS:
// - -fno-mir-opt=*
// - -fno-lir-opt=*
// - -fno-asmir-opt=*
// CONTAINS:
// - JMP #add1_bb1
// NOTE:
//   Negative case for ASMIR drop-jmp-next: the jump to the immediately following label remains.
cog task main {
    
    cog var sink: u32 = 0;
    var input: u32 = 1;
    
    noinline fn add1(x: u32) -> u32 {
        return x + 1;
    }
    
    sink = add1(input);
}