// EXPECT: pass
// STAGE: lir
// ARGS:
// - -fno-mir-opt=*
// - -fno-lir-opt=*
// CONTAINS:
// - %r1:u32 = mov %r0
// - %r4:u32 = binary.Add %r1, %r3
// NOTE:
//   Unary plus materializes a LIR mov. With copy-prop disabled, later uses still
//   read through the moved value.
cog task main {
    
    cog var sink: u32 = 0;
    
    noinline fn demo(x: u32) -> u32 {
        var y: u32 = +x;
        return y + 1;
    }
    
    sink = demo(2);
}