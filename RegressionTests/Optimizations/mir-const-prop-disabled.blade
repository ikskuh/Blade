// EXPECT: pass
// STAGE: mir
// ARGS:
// - -fno-mir-opt=*
// CONTAINS:
// - binary.Add
// NOTE:
//   Negative case for MIR const-prop: constant arithmetic should remain unfused.
cog task main {
    
    cog var sink: u32 = 0;
    var input: u32 = 40;
    
    fn demo(x: u32) -> u32 {
        return x + 2;
    }
    
    sink = demo(input);
}