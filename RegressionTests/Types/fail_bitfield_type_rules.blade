// EXPECT: fail
// DIAGNOSTICS: TypeMismatch
// NOTE:
//   Bitfields remain nominal aggregate types. Cross-bitfield assignment is rejected.

type Left = bitfield (u32) {
    low: nib,
};

type Right = bitfield (u32) {
    low: nib,
};

cog task main {
    var right: Right = undefined;
    var left: Left = right;
}
