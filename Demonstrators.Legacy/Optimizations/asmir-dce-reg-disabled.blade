// EXPECT: pass
// STAGE: asmir
// ARGS:
// - -fno-asmir-opt=*
// CONTAINS:
// - MOV _r1, _r1
// - ADD _r1, #1
// NOTE:
//   Negative case for ASMIR dce-cog: dead register-only instructions remain.

cog var sink: u32 = 0;
var x: u32 = 1;
var y: u32 = 2;

asm {
  MOV {x}, {y}
  ADD {x}, #1
};

sink = 0;
