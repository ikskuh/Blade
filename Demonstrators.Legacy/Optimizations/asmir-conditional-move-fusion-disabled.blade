// EXPECT: pass
// STAGE: asmir
// ARGS:
// - -fno-asmir-opt=conditional-move-fusion
// SEQUENCE:
// - IF_Z JMP #__asm_0_0_done
// - MOV g_sink, #1
// - __asm_0_0_done
// NOTE:
//   Inline asm provides a stable jump-over-single-instruction trigger for the
//   ASMIR conditional-move-fusion pass.

cog var sink: u32 = 0;
asm {
  CMP {sink}, #0 WZ
  IF_Z JMP #done
  MOV {sink}, #1
done:
};
