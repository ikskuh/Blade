// EXPECT: pass
// STAGE: bound
// CONTAINS:
// - Member<u32> .lo
// - TargetMember<u32> .hi

type Pair = struct {
    lo: u32,
    hi: u32,
};

type Header = union {
    pair: Pair,
    lo: u32,
    hi: u32,
};

cog var header: Header = undefined;

fn touch_union_members() {
    var first: u32 = header.lo;
    header.hi = first;
}
