//   This sample showcases a function with exactly two return values.

fn divmod(a: u32, b: u32) -> u32, bool {
    if (a >= b) {
        return a, true;
    }
    else {
        return b, false;
    }
}

cog const in_a: u32 = 100;
cog const in_b: u32 = 50;
cog var result: u32 = 0;
cog var flag: bool = false;

result, flag = divmod(in_a, in_b);
