// EXPECT: pass
// NOTE:
//   Exercises noirq block lowering to REP with @label body-length calculation.

extern cog var OUTA: u32 @(0x1FC);

noinline fn atomic_update(value: u32) -> u32 {
    var result: u32 = value;
    noirq {
        result = result + 1;
    }
    return result;
}

cog var v: u32 = 10;
OUTA = atomic_update(v);
