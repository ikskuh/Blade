// EXPECT: fail
// DIAGNOSTICS:
// - InvalidPointerArithmetic
// NOTE:
//   Covers subtracting a single pointer (*) from a multi-pointer ([*]).
//   Exercises the path where right operand is PointerLikeTypeSymbol but not MultiPointerTypeSymbol.

hub var buf: [10]u32 = undefined;
hub var scalar: u32 = 0;

fn test() {
    var mp: [*]hub u32 = &buf;
    var sp: *hub u32 = &scalar;
    // multi-pointer minus single-pointer → InvalidPointerArithmetic
    var diff: u32 = mp - sp;
}
