// EXPECT: fail
// DIAGNOSTICS: AssertionFailed, TypeMismatch
// NOTE:
//   Covers assertion failure paths and non-bool assert conditions.

// Static assertion that evaluates to false
assert 1 == 2;

// Static assertion with message that evaluates to false
assert 1 == 2, "one does not equal two";

// Static assertion with non-bool condition
assert 42;
