// EXPECT: pass
// STAGE: bound
// CONTAINS:
// - VarDecl result: u32
// - Literal<u32> 11
// ! Call<u32> ct_noirq
// NOTE:
//   Exercises noirq block inside comptime evaluation.

comptime fn ct_noirq(x: u32) -> u32 {
    var result: u32 = x;
    noirq {
        result = result + 1;
    }
    return result;
}

var result: u32 = ct_noirq(10);
