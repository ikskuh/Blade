// EXPECT: pass
// NOTE:
//   Exercises signed arithmetic and comparison AsmLowerer paths.

cog var sink: i32 = 0;
cog var sink_bool: bool = false;
cog var a: i32 = -50;
cog var b: i32 = 30;

fn signed_mul(x: i32, y: i32) -> i32 {
    return x * y;
}

fn signed_div(x: i32, y: i32) -> i32 {
    return x / y;
}

fn signed_mod(x: i32, y: i32) -> i32 {
    return x % y;
}

fn signed_less(x: i32, y: i32) -> bool {
    return x < y;
}

fn signed_greater(x: i32, y: i32) -> bool {
    return x > y;
}

fn signed_leq(x: i32, y: i32) -> bool {
    return x <= y;
}

fn signed_geq(x: i32, y: i32) -> bool {
    return x >= y;
}

sink = signed_mul(a, b);
sink = signed_div(a, b);
sink = signed_mod(a, b);
sink_bool = signed_less(a, b);
sink_bool = signed_greater(a, b);
sink_bool = signed_leq(a, b);
sink_bool = signed_geq(a, b);
