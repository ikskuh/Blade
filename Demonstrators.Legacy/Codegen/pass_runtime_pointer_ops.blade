// EXPECT: pass
// NOTE:
//   Exercises runtime hub memory access AsmLowerer paths.

hub var buf: [8]u32 = undefined;
cog var sink: u32 = 0;

noinline fn store_at(ptr: *hub u32, val: u32) {
    ptr.* = val;
}

noinline fn load_from(ptr: *hub u32) -> u32 {
    return ptr.*;
}

store_at(&buf[0], 100);
store_at(&buf[1], 200);
sink = load_from(&buf[0]);
sink = load_from(&buf[1]);
